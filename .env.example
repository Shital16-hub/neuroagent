# ══════════════════════════════════════════════════════════════════════════════
# NeuroAgent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Providers ─────────────────────────────────────────────────────────────

# Groq API — PRIMARY (Required)
# Free tier at https://console.groq.com — no credit card needed
# Rate limit: 30 req/min on free tier
GROQ_API_KEY=your_groq_api_key_here

# OpenAI — FALLBACK (Optional)
# Only used if GROQ_API_KEY is unavailable or explicitly selected
# Leave blank to disable OpenAI fallback
OPENAI_API_KEY=

# Ollama — LOCAL (Optional)
# Run locally: `ollama run llama3.1:8b`
# Set to http://localhost:11434 to enable
OLLAMA_BASE_URL=

# ── LLM Configuration ─────────────────────────────────────────────────────────

# Primary model for fast tasks (summarization, extraction)
DEFAULT_LLM_MODEL=llama-3.1-8b-instant

# Model for reasoning tasks (contradiction detection, synthesis)
REASONING_LLM_MODEL=deepseek-r1-distill-llama-70b

# Embedding model (used for Qdrant vector search)
# Runs locally via HuggingFace — no API key needed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Vector Database (Qdrant) ──────────────────────────────────────────────────

# Local Docker: http://localhost:6333
# Qdrant Cloud: https://your-cluster.qdrant.io
QDRANT_URL=http://localhost:6333

# Only required for Qdrant Cloud — leave blank for local
QDRANT_API_KEY=

# Collection names
QDRANT_PAPERS_COLLECTION=papers
QDRANT_CONCEPTS_COLLECTION=concepts

# ── Graph Database (Neo4j) ────────────────────────────────────────────────────

# Local Docker: bolt://localhost:7687
# Neo4j AuraDB (free): neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neuroagent_dev

# ── Application Database (MongoDB) ───────────────────────────────────────────

# Local Docker: mongodb://localhost:27017
# MongoDB Atlas (free): mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=neuroagent

# ── Data Sources ──────────────────────────────────────────────────────────────

# Semantic Scholar API key (Optional — increases rate limits)
# Free key at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# NCBI/PubMed API key (Optional — increases rate limits from 3 to 10 req/sec)
# Free key at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# ── Observability (LangSmith) ─────────────────────────────────────────────────

# Free tier: 5000 traces/month at https://smith.langchain.com
# Set LANGCHAIN_TRACING_V2=false to disable tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=neuroagent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Application Configuration ─────────────────────────────────────────────────

APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Maximum papers to fetch per query (higher = slower but more thorough)
MAX_PAPERS_PER_QUERY=15

# How many papers to summarize in parallel (tune to stay within rate limits)
SUMMARIZER_CONCURRENCY=5

# RAGAS evaluation: run async after synthesis (true = non-blocking)
RAGAS_BACKGROUND_EVAL=true

# ── Security ──────────────────────────────────────────────────────────────────

# Secret key for session signing (generate with: openssl rand -hex 32)
SECRET_KEY=change_this_to_a_random_secret_key_in_production

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for the FastAPI CORS middleware
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:7860
